# ============================
# Frontend Environment Variables
# ============================
# Copy this file to .env.local and fill in the values

# Stripe publishable key (pk_test_… / pk_live_…) — must match STRIPE_SECRET_KEY mode on backend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Sign-In — create OAuth "Web client" in Google Cloud Console
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Facebook Login — create app in Facebook Developers Console
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# API base URL for browser (leave empty for dev — Next.js proxies /api to Express)
# For Vercel + Render: https://your-backend.onrender.com/api
# NEXT_PUBLIC_API_URL=

# Where Next.js proxies /api requests (dev default: http://127.0.0.1:5000)
# BACKEND_PROXY_TARGET=http://127.0.0.1:5000

# Server-side fetch URL (RSC) when NEXT_PUBLIC_API_URL is unset
# INTERNAL_API_URL=http://127.0.0.1:5000/api

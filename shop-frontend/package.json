{
  "name": "shop-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_DISABLE_WEBPACK_CACHE=1 next dev -p 3000",
    "dev:turbo": "next dev --turbo -p 3000",
    "dev:cache": "next dev -p 3000",
    "clean": "npx --yes rimraf@5 .next node_modules/.cache",

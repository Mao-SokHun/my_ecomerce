# Database (PostgreSQL)
# Local:    postgresql://postgres:postgres@localhost:5432/shopdb?schema=public
# Supabase: postgresql://postgres.[REF]:[PASS]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopdb?schema=public"
DB_HEALTH_TIMEOUT_MS=5000

# JWT (use a long random string; production requires length >= 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# Seed admin account (use real values only in local/Render env, not in Git)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-admin-password"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Comma-separated for multiple sites, e.g. https://shop.vercel.app,https://preview-xxx.vercel.app
# Or set CORS_ALLOW_VERCEL=1 to allow any https://*.vercel.app (preview + production on Vercel).
# CORS_ALLOW_VERCEL=1

# Stripe — set STRIPE_SECRET_KEY for real card checkout (Payment Element).
# Dashboard webhook URL: https://<your-backend-host>/api/payments/stripe/webhook  (raw JSON body)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# SMTP (Invoice Email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="ShopHub <your_email@gmail.com>"

# Twilio (Invoice SMS)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_PHONE="+1234567890"

# Telegram notifications
# Order/payment notifications use TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID.
# Login/register notifications prefer TELEGRAM_USER_BOT_TOKEN + TELEGRAM_USER_CHAT_ID.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_USER_BOT_TOKEN=""
TELEGRAM_USER_CHAT_ID=""

# KHQR / Bakong
KHQR_PROVIDER="mock" # mock | static | aba
KHQR_MERCHANT_NAME="ShopHub Online Store"
KHQR_MERCHANT_CITY="Phnom Penh"
KHQR_MERCHANT_ID="shophub@aba"
KHQR_STATIC_QR_IMAGE_URL=""
ABA_KHQR_CREATE_URL=""
ABA_KHQR_API_KEY=""
ABA_KHQR_WEBHOOK_SECRET=""
# Required in production when KHQR_PROVIDER=aba (HMAC verification of payment webhooks).
BACKEND_PUBLIC_URL=""

# ═══════════════════════════════════════════════════════════════
# ABA PayWay (Checkout / Card / DeepLink)
# Get Merchant ID and API Key from ABA Bank after registering.
# ═══════════════════════════════════════════════════════════════
#
# ── SANDBOX (Testing - no real money) ──
# Use these URLs while developing and testing:
# ABA_PAYWAY_URL="https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/purchase"
# ABA_PAYWAY_CHECK_URL="https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/check-transaction-2"
#
# ── LIVE (Production - real money) ──
# Switch to these URLs when ready to accept real payments:
# ABA_PAYWAY_URL="https://checkout.payway.com.kh/api/payment-gateway/v1/payments/purchase"
# ABA_PAYWAY_CHECK_URL="https://checkout.payway.com.kh/api/payment-gateway/v1/payments/check-transaction-2"
#
ABA_MERCHANT_ID=""
ABA_API_KEY=""
ABA_PAYWAY_URL="https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/purchase"
ABA_PAYWAY_CHECK_URL="https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/check-transaction-2"
# BACKEND_URL is used for ABA callback; must be the public URL where ABA can reach your server.
BACKEND_URL=""
# Optional: comma-separated ABA server IPs for callback security (get from ABA)
# ABA_ALLOWED_IPS=""

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# Prisma seed — Cambodia locations (Chinese labels via Google translate gtx)
# CAMBODIA_SKIP_TRANSLATION=1  → skip all remote zh (nameZh empty); fastest seed for CI/Render.
# CAMBODIA_SKIP_ZH_PREFETCH=1  → skip the ~10k prefetch loop; upserts still set nameZh from cache/API.
# With committed shop-backend/src/data/cambodia_location_zh_cache.json, prefetch is mostly cache hits (fast).
CAMBODIA_SKIP_TRANSLATION=
CAMBODIA_SKIP_ZH_PREFETCH=

        <mxCell id="fe" value="&lt;b&gt;shop-frontend&lt;/b&gt; — Next.js (App Router)&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size: 11px&quot;&gt;&lt;b&gt;src/app&lt;/b&gt;&lt;br&gt;• &lt;i&gt;(auth)&lt;/i&gt; — login, register&lt;br&gt;• &lt;i&gt;(main)&lt;/i&gt; — home, products, cart, checkout, dashboard, legal&lt;br&gt;• &lt;i&gt;admin&lt;/i&gt; — orders, products, categories, coupons, users, settings, support&lt;br&gt;&lt;br&gt;&lt;b&gt;src/components&lt;/b&gt; — auth, cart, chat, common, home, layout, payment, products, ui&lt;br&gt;&lt;b&gt;src/lib&lt;/b&gt; — api, i18n, utils, …&lt;br&gt;&lt;b&gt;src/store&lt;/b&gt; — Zustand (auth, cart, language, …)&lt;br&gt;&lt;b&gt;src/hooks&lt;/b&gt; · &lt;b&gt;src/types&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#1565c0&quot;&gt;public/ · tailwind · next.config&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="380" height="380" as="geometry" />
        </mxCell>
        <mxCell id="be" value="&lt;b&gt;shop-backend&lt;/b&gt; — Express + Prisma&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size: 11px&quot;&gt;&lt;b&gt;Entry&lt;/b&gt; — app.ts, server.ts&lt;br&gt;&lt;br&gt;&lt;b&gt;src/routes&lt;/b&gt; — auth, admin, products, categories, cart, orders, payments, reviews, settings, upload, user, location, support, leads&lt;br&gt;&lt;br&gt;&lt;b&gt;src/controllers&lt;/b&gt; — mirrors route domains&lt;br&gt;&lt;b&gt;src/middleware&lt;/b&gt; — auth, rate limits, …&lt;br&gt;&lt;b&gt;src/lib&lt;/b&gt; — Stripe, KHQR, invoice, uploads, …&lt;br&gt;&lt;b&gt;src/data&lt;/b&gt; · &lt;b&gt;src/utils&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;prisma/&lt;/b&gt; schema.prisma, migrations/, seed.ts&lt;br&gt;&lt;b&gt;uploads/&lt;/b&gt; — avatars, product images&lt;br&gt;&lt;b&gt;scripts/&lt;/b&gt; — maintenance&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
